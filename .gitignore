# Dependencies & build output
node_modules/
dist/

# Offline OCR model (download with: cd backend && npm run fetch-ocr-model)
backend/ocr-data/

# Built frontend copied into the backend at deploy time
backend/public/

# Terraform
infra/.terraform/
infra/.terraform.lock.hcl
infra/*.tfstate
infra/*.tfstate.*
infra/terraform.tfvars

# Secrets (keep .env.example)
.env
.env.local

# Python
__pycache__/
*.pyc

# Evaluation cache — regenerable; RESULTS.md is the committed result
data-exploration/model_test/.cache.json

# Raw dataset — shipped as split parts data-exploration/dataset.zip.001..006
# (GitHub caps single files at 100MB). The reassembled zip and the unzipped
# folders are reproduced locally and are not tracked.
data-exploration/dataset.zip
data-exploration/label_images/
data-exploration/application/
data-exploration/batch_sample/
